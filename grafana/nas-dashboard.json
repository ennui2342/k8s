{
  "dashboard": {
    "title": "NAS Monitor",
    "uid": "nas-monitor",
    "timezone": "browser",
    "refresh": "1m",
    "time": { "from": "now-6h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "type": "timeseries",
        "title": "CPU Load per Core (%)",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "targets": [
          {
            "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" },
            "query": "SELECT mean(\"load\") FROM \"nas_30d\".\"nas_cpu\" WHERE $timeFilter GROUP BY time($__interval) fill(null)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" }
      },
      {
        "id": 2,
        "type": "timeseries",
        "title": "Memory Usage (%)",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "targets": [
          {
            "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" },
            "query": "SELECT mean(\"used\") / mean(\"size\") * 100 FROM \"nas_30d\".\"nas_storage\" WHERE \"description\"='Physical memory' AND $timeFilter GROUP BY time($__interval) fill(null)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" }
      },
      {
        "id": 3,
        "type": "timeseries",
        "title": "/mnt/md0 Disk Usage (%)",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "targets": [
          {
            "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" },
            "query": "SELECT mean(\"used\") / mean(\"size\") * 100 FROM \"nas_30d\".\"nas_storage\" WHERE \"description\"='/mnt/md0' AND $timeFilter GROUP BY time($__interval) fill(null)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" }
      },
      {
        "id": 4,
        "type": "timeseries",
        "title": "eth0 Network Throughput",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "fieldConfig": {
          "defaults": {
            "unit": "Bps"
          },
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "bytes_out" },
              "properties": [
                { "id": "custom.transform", "value": "negative-Y" }
              ]
            }
          ]
        },
        "targets": [
          {
            "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" },
            "query": "SELECT non_negative_derivative(mean(\"bytes_in\"), 1s) AS \"bytes_in\", non_negative_derivative(mean(\"bytes_out\"), 1s) AS \"bytes_out\" FROM \"nas_30d\".\"nas_network\" WHERE \"ifname\"='eth0' AND $timeFilter GROUP BY time($__interval) fill(null)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" }
      },
      {
        "id": 5,
        "type": "gauge",
        "title": "/mnt/md0 Disk Usage (current)",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "red", "value": 90 }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] }
        },
        "targets": [
          {
            "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" },
            "query": "SELECT last(\"used\") / last(\"size\") * 100 FROM \"nas_30d\".\"nas_storage\" WHERE \"description\"='/mnt/md0' AND $timeFilter",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" }
      },
      {
        "id": 6,
        "type": "gauge",
        "title": "Memory Usage (current)",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "red", "value": 90 }
              ]
            }
          }
        },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] }
        },
        "targets": [
          {
            "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" },
            "query": "SELECT last(\"used\") / last(\"size\") * 100 FROM \"nas_30d\".\"nas_storage\" WHERE \"description\"='Physical memory' AND $timeFilter",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" }
      },
      {
        "id": 7,
        "type": "timeseries",
        "title": "All Storage Usage (%)",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100
          }
        },
        "targets": [
          {
            "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" },
            "query": "SELECT mean(\"used\") / mean(\"size\") * 100 FROM \"nas_30d\".\"nas_storage\" WHERE $timeFilter GROUP BY time($__interval), \"description\" fill(null)",
            "rawQuery": true,
            "resultFormat": "time_series",
            "refId": "A"
          }
        ],
        "datasource": { "type": "influxdb", "uid": "Kb3eTeiRk" }
      }
    ],
    "schemaVersion": 36,
    "version": 0
  },
  "overwrite": true
}
