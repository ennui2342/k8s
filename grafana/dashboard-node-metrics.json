{
  "dashboard": {
    "description": "Cluster node resource utilisation via node-exporter. Series are identified by pod_name (node-exporter-* suffix maps to a node; pod names change on DaemonSet rollout).",
    "panels": [
      {
        "datasource": null,
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "lineWidth": 2
            }
          }
        },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
        "id": 1,
        "targets": [
          {
            "datasource": null,
            "query": "SELECT mean(\"node_load1\") FROM \"prometheus\" WHERE $timeFilter GROUP BY time($__interval), \"pod_name\" fill(none)",
            "rawQuery": true,
            "refId": "A",
            "resultFormat": "time_series"
          },
          {
            "datasource": null,
            "query": "SELECT mean(\"node_load5\") FROM \"prometheus\" WHERE $timeFilter GROUP BY time($__interval), \"pod_name\" fill(none)",
            "rawQuery": true,
            "refId": "B",
            "resultFormat": "time_series"
          },
          {
            "datasource": null,
            "query": "SELECT mean(\"node_load15\") FROM \"prometheus\" WHERE $timeFilter GROUP BY time($__interval), \"pod_name\" fill(none)",
            "rawQuery": true,
            "refId": "C",
            "resultFormat": "time_series"
          }
        ],
        "title": "Load Average (1m / 5m / 15m)",
        "type": "timeseries"
      },
      {
        "datasource": null,
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "min": 0,
            "unit": "percent"
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "id": 2,
        "targets": [
          {
            "datasource": null,
            "query": "SELECT 100 * (1 - mean(\"node_memory_MemAvailable_bytes\") / mean(\"node_memory_MemTotal_bytes\")) FROM \"prometheus\" WHERE $timeFilter GROUP BY time($__interval), \"pod_name\" fill(none)",
            "rawQuery": true,
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "title": "Memory Usage (%)",
        "type": "timeseries"
      },
      {
        "datasource": null,
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "min": 0,
            "unit": "percent"
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "id": 3,
        "targets": [
          {
            "datasource": null,
            "query": "SELECT 100 * (1 - mean(\"node_filesystem_avail_bytes\") / mean(\"node_filesystem_size_bytes\")) FROM \"prometheus\" WHERE \"mountpoint\"='/' AND $timeFilter GROUP BY time($__interval), \"pod_name\" fill(none)",
            "rawQuery": true,
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "title": "Root Disk Usage (%)",
        "type": "timeseries"
      },
      {
        "datasource": null,
        "fieldConfig": {
          "defaults": {
            "max": 100,
            "min": 0,
            "unit": "percent"
          }
        },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
        "id": 4,
        "targets": [
          {
            "datasource": null,
            "query": "SELECT 100 * (1 - non_negative_derivative(mean(\"node_cpu_seconds_total\"), 1s)) FROM \"prometheus\" WHERE \"mode\"='idle' AND $timeFilter GROUP BY time($__interval), \"pod_name\" fill(none)",
            "rawQuery": true,
            "refId": "A",
            "resultFormat": "time_series"
          }
        ],
        "title": "CPU Usage (%)",
        "type": "timeseries"
      },
      {
        "datasource": null,
        "fieldConfig": {
          "defaults": {
            "unit": "Bps"
          },
          "overrides": [
            {
              "matcher": {
                "id": "byFrameRefID",
                "options": "B"
              },
              "properties": [
                {
                  "id": "custom.transform",
                  "value": "negative-Y"
                }
              ]
            }
          ]
        },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
        "id": 5,
        "targets": [
          {
            "datasource": null,
            "query": "SELECT non_negative_derivative(mean(\"node_network_receive_bytes_total\"), 1s) FROM \"prometheus\" WHERE \"device\"='eth0' AND $timeFilter GROUP BY time($__interval), \"pod_name\" fill(none)",
            "rawQuery": true,
            "refId": "A",
            "resultFormat": "time_series"
          },
          {
            "datasource": null,
            "query": "SELECT non_negative_derivative(mean(\"node_network_transmit_bytes_total\"), 1s) FROM \"prometheus\" WHERE \"device\"='eth0' AND $timeFilter GROUP BY time($__interval), \"pod_name\" fill(none)",
            "rawQuery": true,
            "refId": "B",
            "resultFormat": "time_series"
          }
        ],
        "title": "Network Throughput (eth0) — Rx up / Tx down",
        "type": "timeseries"
      },
      {
        "datasource": null,
        "fieldConfig": {
          "defaults": {
            "unit": "Bps"
          },
          "overrides": [
            {
              "matcher": {
                "id": "byFrameRefID",
                "options": "B"
              },
              "properties": [
                {
                  "id": "custom.transform",
                  "value": "negative-Y"
                }
              ]
            }
          ]
        },
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
        "id": 6,
        "targets": [
          {
            "datasource": null,
            "query": "SELECT non_negative_derivative(mean(\"node_disk_read_bytes_total\"), 1s) FROM \"prometheus\" WHERE \"device\"='mmcblk0' AND $timeFilter GROUP BY time($__interval), \"pod_name\" fill(none)",
            "rawQuery": true,
            "refId": "A",
            "resultFormat": "time_series"
          },
          {
            "datasource": null,
            "query": "SELECT non_negative_derivative(mean(\"node_disk_written_bytes_total\"), 1s) FROM \"prometheus\" WHERE \"device\"='mmcblk0' AND $timeFilter GROUP BY time($__interval), \"pod_name\" fill(none)",
            "rawQuery": true,
            "refId": "B",
            "resultFormat": "time_series"
          }
        ],
        "title": "Disk I/O (mmcblk0) — Read up / Write down",
        "type": "timeseries"
      }
    ],
    "refresh": "1m",
    "schemaVersion": 27,
    "time": {
      "from": "now-3h",
      "to": "now"
    },
    "timezone": "browser",
    "title": "Node Metrics",
    "uid": "node-metrics",
    "version": 0
  },
  "overwrite": true
}
